rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwnUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasValidDocumentDataOnCreate(documentationSuiteId) {
      return request.resource.data.documentationSuiteId == documentationSuiteId;
    }

    function isDocumentDataImmutable() {
      return request.resource.data.documentationSuiteId == resource.data.documentationSuiteId;
    }

    function hasOnlyAllowedSelfProfileFields() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['name', 'company', 'phone', 'updatedAt', 'lastLoginAt']);
    }

    match /users/{userId} {
      allow get: if isOwnUser(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwnUser(userId);
      allow update: if (isOwnUser(userId) && hasOnlyAllowedSelfProfileFields()) || isAdmin();
      allow delete: if false;
    }

    match /roles_admin/{userId} {
      allow get: if isOwnUser(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /documentation_suites/{documentationSuiteId} {
      allow get, list: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();

      match /documents/{documentId} {
        allow get, list: if resource.data.status == 'published' || isAdmin();
        allow create: if isAdmin() && hasValidDocumentDataOnCreate(documentationSuiteId);
        allow update: if isAdmin() && isDocumentDataImmutable();
        allow delete: if isAdmin();
      }
    }

    match /membership_plans/{planId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /membership_history/{historyId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /member_notes/{noteId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /member_overrides/{overrideId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }



    match /membership_access_grants/{grantId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /subscriptions/{subscriptionId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /billing_history/{eventId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /customisation_requests/{requestId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.memberId == request.auth.uid);
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /support_requests/{requestId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.memberId == request.auth.uid);
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /discovery_calls/{callId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.memberId == request.auth.uid);
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /user_saved_items/{itemId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.memberId == request.auth.uid);
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.memberId == request.auth.uid);
    }

    match /user_recent_activity/{activityId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.memberId == request.auth.uid);
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.memberId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /square_webhook_events/{eventId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }
    function isValidKnowledgeType(value) {
      return value in ['article', 'guide', 'tool', 'knowledge_base'];
    }

    match /knowledge_articles/{articleId} {
      allow get, list: if resource.data.published == true || isAdmin();
      allow create, update: if isAdmin()
        && request.resource.data.title is string
        && request.resource.data.slug is string
        && request.resource.data.content is string
        && request.resource.data.published is bool
        && isValidKnowledgeType(request.resource.data.contentType);
      allow delete: if isAdmin();
    }



    match /site_pages/{pageId} {
      allow get, list: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /service_pages/{serviceId} {
      allow get, list: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /faqs/{faqId} {
      allow get, list: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /partner_offers/{offerId} {
      allow get, list: if resource.data.active == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow get, list: if resource.data.active == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /past_projects/{projectId} {
      allow get, list: if resource.data.active == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.audienceRole in ['all', 'member']));
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read', 'readAt']));
      allow delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow get, list: if resource.data.active == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /analytics_events/{eventId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /audit_logs/{logId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /content_revisions/{revisionId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /email_logs/{emailLogId} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /contact_enquiries/{enquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
