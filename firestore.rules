rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwnUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasValidDocumentDataOnCreate(documentationSuiteId) {
      return request.resource.data.documentationSuiteId == documentationSuiteId;
    }

    function isDocumentDataImmutable() {
      return request.resource.data.documentationSuiteId == resource.data.documentationSuiteId;
    }

    match /users/{userId} {
      allow get: if isOwnUser(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwnUser(userId);
      allow update: if isOwnUser(userId) || isAdmin();
      allow delete: if false;
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /documentation_suites/{documentationSuiteId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();

      match /documents/{documentId} {
        allow get, list: if true;
        allow create: if isAdmin() && hasValidDocumentDataOnCreate(documentationSuiteId);
        allow update: if isAdmin() && isDocumentDataImmutable();
        allow delete: if isAdmin();
      }
    }

    match /membership_plans/{planId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /knowledge_articles/{articleId} {
      allow get, list: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /partner_offers/{offerId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /past_projects/{projectId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow get: if isAdmin() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.audienceRole in ['all', 'member']));
      allow list: if isAdmin() || isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow get, list: if resource.data.active == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /analytics_events/{eventId} {
      allow create: if isSignedIn() || request.auth == null;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /content_revisions/{revisionId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /membership_history/{historyId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    match /email_logs/{emailLogId} {
      allow read, create: if isAdmin();
      allow update, delete: if false;
    }

    match /contact_enquiries/{enquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
