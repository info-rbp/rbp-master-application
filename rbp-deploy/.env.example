# RBP deploy/app bootstrap environment example
# NOTE: This file intentionally contains NO secret values.
# Use *_REF keys to point to secret-manager references.

# --- Environment identity ---
ENVIRONMENT=dev
NODE_ENV=development
APP_BASE_URL=https://app-dev.<replace-domain>
API_BASE_URL=https://app-dev.<replace-domain>/api
ADMIN_PATH=/admin

# --- Firebase / GCP ---
FIREBASE_PROJECT_ID=<replace-dev-firebase-project>
GCP_PROJECT_ID=<replace-dev-gcp-project>
FIRESTORE_DATABASE=(default)
RBP_APP_HOSTING_BACKEND_ID=rbp-master-application
PRIMARY_STORAGE_BUCKET=rbp-dev-app-assets
DOCUMENT_STORAGE_BUCKET=rbp-dev-documents

# --- Auth (non-secret values only) ---
AUTHENTIK_ISSUER_URL=https://auth-dev.<replace-domain>/application/o/rbp/
AUTHENTIK_CLIENT_ID=rbp-master-app
AUTHENTIK_REDIRECT_URI=https://app-dev.<replace-domain>/api/auth/callback
AUTHENTIK_POST_LOGOUT_REDIRECT_URI=https://app-dev.<replace-domain>/login
SESSION_COOKIE_NAME=rbp_session

# --- Integration endpoints (non-secret) ---
ODOO_BASE_URL=https://odoo-dev.internal
LENDING_BASE_URL=https://lending-dev.internal
MARBLE_BASE_URL=https://marble-dev.internal
N8N_BASE_URL=https://n8n-dev.internal
DOCSPELL_BASE_URL=https://docspell-dev.internal
METABASE_BASE_URL=https://metabase-dev.internal

# --- Runtime controls ---
PLATFORM_INTEGRATION_TIMEOUT_MS=8000
PLATFORM_INTEGRATION_RETRY_COUNT=2
PLATFORM_INTEGRATION_DEBUG=true
FEATURE_PREVIEW_ENABLED=true
AUDIT_SINK=firestore
NOTIFICATION_SINK=platform_default
LOGGING_DESTINATION=gcp-logging-dev
MONITORING_DESTINATION=gcp-monitoring-dev
ALERTING_TARGET_REF=pagerduty:rbp-dev-primary
LOCAL_AUTH_ENABLED=true
RBP_CONTROL_PLANE_COLLECTION=platform_control_plane

# --- Secret references only (NOT secret values) ---
AUTHENTIK_CLIENT_SECRET_REF=ref:rbp/dev/rbp-master-application/AUTHENTIK_CLIENT_SECRET
SESSION_SECRET_REF=ref:rbp/dev/rbp-master-application/SESSION_SECRET
ODOO_API_KEY_REF=ref:rbp/dev/odoo/ODOO_API_KEY
ODOO_PASSWORD_REF=ref:rbp/dev/odoo/ODOO_PASSWORD
LENDING_API_KEY_REF=ref:rbp/dev/lending/LENDING_API_KEY
LENDING_API_SECRET_REF=ref:rbp/dev/lending/LENDING_API_SECRET
MARBLE_API_KEY_REF=ref:rbp/dev/marble/MARBLE_API_KEY
N8N_API_KEY_REF=ref:rbp/dev/n8n/N8N_API_KEY
N8N_WEBHOOK_SIGNING_SECRET_REF=ref:rbp/dev/n8n/N8N_WEBHOOK_SIGNING_SECRET
DOCSPELL_API_TOKEN_REF=ref:rbp/dev/docspell/DOCSPELL_API_TOKEN
METABASE_EMBED_SECRET_REF=ref:rbp/dev/metabase/METABASE_EMBED_SECRET
