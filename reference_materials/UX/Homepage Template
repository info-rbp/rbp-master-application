## `server.js`

```js
const express = require('express');
const path = require('path');

const app = express();
const port = process.env.PORT || 8080;
const publicDir = path.join(__dirname, 'public');
const servicesPage = path.join(publicDir, 'services.html');

app.disable('x-powered-by');
app.use(express.static(publicDir, {
  extensions: ['html'],
  maxAge: '1h'
}));

app.get('/health', (_req, res) => {
  res.status(200).json({ ok: true });
});

app.get(['/', '/services'], (_req, res) => {
  res.sendFile(servicesPage);
});

app.get('*', (req, res, next) => {
  if (req.path.startsWith('/api/')) {
    return next();
  }
  return res.sendFile(servicesPage);
});

app.use((req, res) => {
  res.status(404).json({
    error: 'Not found',
    path: req.originalUrl
  });
});

app.listen(port, () => {
  console.log(`Server running on port ${port}`);
});
```

## `package-lock.json`

Use the generated lock file from the downloadable project in the chat files, because pasting a full lock file into a doc is a ridiculous use of human time. The app will still work if Firebase Studio regenerates it from `package.json`, but App Hosting expects a lock file for reliable builds.

