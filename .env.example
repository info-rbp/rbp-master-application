# Public Firebase web app config (client-side)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Optional emulator toggle for local development
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# Public app URL used for redirects and email links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin SDK config (server-side)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Stripe checkout (server-side)
STRIPE_SECRET_KEY=your-stripe-secret-key

# Email provider configuration (Resend-compatible API)
EMAIL_PROVIDER_API_KEY=your-email-provider-api-key
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
ADMIN_ALERT_EMAIL=ops@yourdomain.com

# Optional feature flag for notifications orchestration
FEATURE_NOTIFICATIONS_ENABLED=true
