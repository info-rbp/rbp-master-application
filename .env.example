# Public Firebase web app config (client-side)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Optional emulator toggle for local development
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false

# Public app URL used for redirects, webhook validation URL construction, and email links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Firebase Admin SDK config (server-side)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# Square subscriptions (server-side)
# Use a sandbox token for local/staging and a production token for live.
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=your-square-location-id
SQUARE_WEBHOOK_SIGNATURE_KEY=your-square-webhook-signature-key

# Email provider configuration (Resend-compatible API)
EMAIL_PROVIDER_API_KEY=your-email-provider-api-key
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_PROVIDER=resend
ADMIN_ALERT_EMAIL=ops@yourdomain.com
EMAIL_RESOURCE_PUBLISH_ENABLED=false

# Optional feature flag for notifications orchestration
FEATURE_NOTIFICATIONS_ENABLED=true
